# ============================================================
# Q-FENG Validation - .gitignore
# Politica: versionar ativos academicos e cientificos por padrao;
# excluir caches, builds, dados regeneraveis e backups forenses.
# Ultima revisao: 26/abr/2026 (Op. C)
# ============================================================

# --- Python: byte-compiled / virtualenvs ---
__pycache__/
*.py[cod]
*$py.class

.venv/
venv/
ENV/

# --- IDE / editores ---
.vscode/
.idea/
*.swp
*.swo

# --- Caches de tooling ---
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- OS / sistema ---
Thumbs.db
.DS_Store

# --- Jupyter ---
.ipynb_checkpoints/

# --- Distribuicao Python ---
dist/
build/
*.egg-info/

# --- Backups e lockfiles do MS Office ---
*.bak_*
~$*
*.tmp

# --- Secrets ---
.env
.env.local
streamlit_app/.streamlit/secrets.toml

# ============================================================
# Dados grandes - regeneraveis ou de proveniencia externa
# ============================================================

# Datasets pesados, baixados/regeneraveis via scripts
data/datasus/
data/obermeyer/
data/cms/
data/predictors/

# Corpora normativos brutos - reproduziveis via scripts/download_corpus*.py
corpora/

# Grafo de conhecimento auto-gerado (graphify hook)
graphify-out/

# Configuracoes internas do Claude Code
.claude/

# ============================================================
# Tabular global - ignora por default, com excecoes pontuais
# ============================================================

*.csv
*.parquet
*.feather

# Excecoes: manifests explicitos, .gitkeep, ground truth Clingo (futuro)
!**/MANIFEST.csv
!**/MANIFEST.md
!**/.gitkeep

# ============================================================
# outputs/ - politica WHITELIST
# Default: ignorar tudo (regeneravel via pipeline E0-E5).
# Excecoes: relatorios *_report.md, manifests, READMEs, .gitkeep.
# ============================================================

outputs/**

# Excecoes para whitelist de outputs/
!outputs/
!outputs/**/
!outputs/**/MANIFEST.md
!outputs/**/README.md
!outputs/**/.gitkeep
!outputs/**/*_report.md
# Fase 2.1.5-bis: outputs auditaveis
!outputs/**/*fase215bis*
!outputs/**/*_decision.json
# Frente 1: logs de execucao, analises e relatorios
!outputs/e5_results/run_log_frente1.txt
!outputs/RELATORIO_FRENTE1_FINAL.md
!outputs/frente1_delta_se_antecipacao.json
!outputs/frente1_analise_descritiva.md
!outputs/figures/
!outputs/figures/**
!outputs/_archive/
!outputs/_archive/**
# Derived parquets Caminho2 (calculados, sem dados brutos pesados)
!data/predictors/
!data/predictors/manaus_bi/
!data/predictors/manaus_bi/derived/
!data/predictors/manaus_bi/derived/*.parquet
!data/predictors/manaus_bi/_archive/
!data/predictors/manaus_bi/_archive/*.parquet

# ============================================================
# docs/ - versionado por default, com excecoes para o repo remoto
# Mantemos backups forenses LOCAL para acesso imediato sem
# precisar consultar historico Git, mas sem inflar o remoto publico.
# ============================================================

# Backups forenses do paper (auditoria local, ~16 MB de .docx redundantes)
docs/papers/paper1/historico_submissoes/docx_backups/

# Lockfiles e backups automaticos do Word dentro de docs/
docs/papers/**/*.bak_*
docs/papers/**/~$*

# ============================================================
# Bibliografia/referencias teoricas - leitura local apenas
# PDFs de papers terceiros (arXiv etc.) sao publicos via DOI/URL;
# manter local para acesso offline mas nao versionar no repo.
# Conversoes .txt para RAG sao derivadas, regeneraveis.
# ============================================================

artefatos/referencias_teoricas/**/*.pdf
artefatos/referencias_teoricas/**/*.txt

# ============================================================
# Notas operacionais
# - O canonico DOCX (docs/papers/paper1/PAPER1_QFENG_FINAL.docx)
#   e versionado deliberadamente como seguro contra falhas de
#   regeneracao via pandoc.
# - Para inspecionar o que esta sendo ignorado: git status --ignored
# - Para forcar inclusao pontual (ex.: parquet pequeno e estavel):
#   git add -f caminho/do/arquivo.parquet
# ============================================================
