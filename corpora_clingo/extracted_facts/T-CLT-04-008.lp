% span: Acordao sobre dano moral trabalhista cita CLT Art. 223-G
legal_decision_issued(acordao_dano_moral_223g).
% span: cita CLT Art. 223-G (pos-reforma 2017)
cita_precedente(acordao_dano_moral_223g, art_223g_clt).
% span: dispositivo legal vigente pos-Reforma 2017
precedente_existe(art_223g_clt).
% span: CLT Art. 223-G (lei+artigo+paragrafo identificados)
precedente_identificado_completo(acordao_dano_moral_223g, art_223g_clt).
% span: identifica o grau da ofensa - representativo do raciocinio descrito (cenario nao fixa um grau especifico)
dano_moral_alegado_grau(acordao_dano_moral_223g, grave).
% span: quantifica o valor com referencia ao salario do trabalhador conforme o art. 223-G 1
quantificacao_dano_fundamentada(acordao_dano_moral_223g).
